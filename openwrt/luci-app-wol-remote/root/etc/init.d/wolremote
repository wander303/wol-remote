#!/bin/sh /etc/rc.common
# WOL Remote - procd init script
#
# 通过 procd 管理轮询守护进程，替代 cron 方案。
# 轮询间隔由 uci get wolremote.settings.poll_interval 控制。

USE_PROCD=1
START=99
STOP=10

SERVICE_WRITE_PID=1

start_service() {
    procd_open_instance
    procd_set_param command /bin/sh /usr/bin/wol-poll.sh
    procd_set_param respawn 0 0 0    # 不自动重启（循环脚本自然恢复）
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
    logger -t "wolremote" "服务已启动"
}

stop_service() {
    logger -t "wolremote" "服务已停止"
}

service_triggers() {
    procd_add_reload_trigger "wolremote"
}

reload_service() {
    # 重新加载配置：stop 后再 start 让脚本读取新配置
    stop
    sleep 1
    start
    logger -t "wolremote" "配置已重载"
}
